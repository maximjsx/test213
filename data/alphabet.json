        { "type": "match_pairs", "id": "alph-2-mp1", "instruction": "Match each letter to its sound:", "pairs": [{ "left": "Е", "right": "e" }, { "left": "Ж", "right": "zh" }, { "left": "З", "right": "z" }, { "left": "И", "right": "ee" }] },
