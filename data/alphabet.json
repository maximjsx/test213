        { "type": "introduce", "id": "alph-1-i3", "label": "NEW LETTER", "display": "В", "sublabel": "\"v\" as in \"vet\"", "tts": "Въ" },
        { "type": "multiple_choice", "id": "alph-1-mc3", "question": "What sound does В make?", "choices": ["\"v\" as in vet", "\"b\" as in bug", "\"d\" as in dog"], "answer": "\"v\" as in vet", "tts": "Въ" },
        { "type": "match_pairs", "id": "alph-1-mp0", "instruction": "Quick check: match the letters you just learned:", "pairs": [{ "left": "А", "right": "a" }, { "left": "Б", "right": "b" }, { "left": "В", "right": "v" }] },
